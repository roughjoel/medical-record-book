<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_surface"
    android:fillViewport="false"
    android:paddingStart="2dp"
    android:paddingTop="10dp"
    android:paddingEnd="2dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dialog_section"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="基础信息"
                android:textColor="#172B4D"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="疾病名称"
                android:textColor="#42526E"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etDiseaseName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_dialog_input"
                android:hint="例如：2026年5月甲流"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#172B4D"
                android:textColorHint="#97A0AF"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="记录日期"
                android:textColor="#42526E"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etDate"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_dialog_input"
                android:hint="例如：2026-05-10"
                android:inputType="date"
                android:maxLines="1"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#172B4D"
                android:textColorHint="#97A0AF"
                android:textSize="15sp" />

            <CheckBox
                android:id="@+id/cbKeyNode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:buttonTint="#E53935"
                android:text="标记为关键节点"
                android:textColor="#172B4D"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_dialog_section"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="病情记录"
                android:textColor="#172B4D"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="症状描述"
                android:textColor="#42526E"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etSymptoms"
                android:layout_width="match_parent"
                android:layout_height="108dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_dialog_input"
                android:gravity="top|start"
                android:hint="填写当天症状、体温、疼痛程度等"
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textColor="#172B4D"
                android:textColorHint="#97A0AF"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="图片"
                android:textColor="#42526E"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickImages"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="6dp"
                android:text="从图库选择图片"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1565C0"
                app:cornerRadius="8dp" />

            <TextView
                android:id="@+id/tvImageSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="未选择图片"
                android:textColor="#6B778C"
                android:textSize="13sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutImagePreview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_dialog_section"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="医疗信息"
                android:textColor="#172B4D"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="医生诊断"
                android:textColor="#42526E"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etDiagnosis"
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_dialog_input"
                android:gravity="top|start"
                android:hint="可为空"
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textColor="#172B4D"
                android:textColorHint="#97A0AF"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="医嘱用药"
                android:textColor="#42526E"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etMedications"
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_dialog_input"
                android:gravity="top|start"
                android:hint="可为空"
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textColor="#172B4D"
                android:textColorHint="#97A0AF"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="备注"
                android:textColor="#42526E"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etNotes"
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_dialog_input"
                android:gravity="top|start"
                android:hint="可为空"
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textColor="#172B4D"
                android:textColorHint="#97A0AF"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
